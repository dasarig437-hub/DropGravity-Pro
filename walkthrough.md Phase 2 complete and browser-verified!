}

.chart-body {
    margin: 0 -12px;
}

.chart-tooltip {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    padding: 8px 12px;
    font-size: 0.75rem;
}

.tooltip-label {
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--text-primary);
}

/* Suggestions */
.suggestions-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.suggestions-title {
    font-size: 0.95rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
}

.suggestions-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.suggestion-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
}

.suggestion-icon {
    flex-shrink: 0;
    color: var(--accent-warning);
    margin-top: 2px;
}

.suggestion-item:first-child .suggestion-icon {
    color: var(--accent-success);
}

/* Weak Metrics */
.weak-metrics-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.weak-metric-item {
    display: flex;
    align-items: center;
    gap: 12px;
}

.wm-name {
    font-size: 0.82rem;
    color: var(--text-secondary);
    min-width: 110px;
}

.wm-bar-track {
    flex: 1;
    height: 6px;
    background: var(--bg-tertiary);
    border-radius: var(--radius-full);
    overflow: hidden;
}

.wm-bar-fill {
    height: 100%;
    border-radius: var(--radius-full);
    transition: width 1s ease;
}

.wm-value {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-danger);
    min-width: 50px;
    text-align: right;
}

/* Saved Products */
.saved-products-section {
    margin-top: -8px;
}

.saved-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
}

.saved-header .suggestions-title {
    margin-bottom: 0;
}

.saved-products-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.saved-product-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    background: var(--bg-glass);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    cursor: default;
}

.saved-product-row:hover {
    background: var(--bg-glass-hover);
    border-color: var(--border-hover);
}

.sp-grade-badge {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.95rem;
    flex-shrink: 0;
}

.sp-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.sp-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    gap: 6px;
}

.sp-version {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: var(--radius-full);
    background: rgba(139, 92, 246, 0.15);
    color: var(--accent-primary);
    flex-shrink: 0;
}

.sp-date {
    font-size: 0.72rem;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 4px;
}

.sp-score {
    display: flex;
    align-items: baseline;
    gap: 2px;
    flex-shrink: 0;
}

.sp-score-value {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-primary);
}

.sp-score-label {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    font-weight: 600;
}

.saved-empty,
.saved-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 40px 20px;
    color: var(--text-tertiary);
    text-align: center;
}

.saved-empty p,
.saved-loading p {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
}

.saved-empty span {
    font-size: 0.78rem;
}

@keyframes spin {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}

.spin-icon {
    animation: spin 1s linear infinite;
}

/* Toast Notifications */
.toast-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 10000;
    pointer-events: none;
    opacity: 0;
    transform: translateY(16px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.toast-container.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}

.toast {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 600;
    backdrop-filter: blur(20px);
    box-shadow: var(--shadow-lg);
    min-width: 280px;
    max-width: 420px;
}

.toast-success {
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: #10b981;
}

.toast-error {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #ef4444;
}

/* Disabled button */
.btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
}

/* Responsive */
@media (max-width: 1200px) {
    .metrics-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .dash-top-row {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .metrics-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .dash-top-row {
        grid-template-columns: 1fr;
    }

    .charts-row {
        grid-template-columns: 1fr;
    }

    .suggestions-section {
        grid-template-columns: 1fr;
    }
}
