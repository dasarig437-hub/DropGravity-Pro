        type: Number,
        default: 1,
    },
    createdAt: {
        type: Date,
        default: Date.now,
    },
});

// Compound index: prevents exact duplicates, allows versioned re-grades
productSchema.index({ userId: 1, productName: 1, version: 1 }, { unique: true });

const Product = mongoose.model('Product', productSchema);

