    display: flex;
    flex-direction: column;
    gap: 2px;
}

.fpc-stat-label {
    font-size: 0.65rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
}

.fpc-stat-value {
    font-size: 0.9rem;
    font-weight: 700;
}

.fpc-prices {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
}

.fpc-cost {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    text-decoration: line-through;
}

.fpc-sell {
    font-size: 0.95rem;
