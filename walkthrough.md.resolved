}

.fpc-trend.rising {
    color: var(--accent-success);
}

.fpc-trend.declining {
    color: var(--accent-danger);
}

.fpc-trend.stable {
    color: var(--accent-warning);
}

.fpc-orders {
    font-size: 0.72rem;
    color: var(--text-tertiary);
}

/* Empty State */
.finder-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 80px 20px;
    text-align: center;
    min-height: 300px;
}

.finder-empty-icon {
    color: var(--text-tertiary);
    opacity: 0.5;
    margin-bottom: 8px;
}

.finder-empty-state h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-secondary);
}

.finder-empty-state p {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    margin-bottom: 8px;
}

/* Responsive */
@media (max-width: 768px) {
    .filters-panel {
        width: 100%;
        position: static;
    }

    .finder-body {
        flex-direction: column;
    }

    .finder-results.grid {
        grid-template-columns: 1fr;
    }
}
